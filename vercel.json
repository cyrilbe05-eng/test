{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...slug]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/[...slug].ts": {
      "maxDuration": 60
    },
    "api/cron/budget-nudge.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/budget-nudge",
      "schedule": "0 9 * * 1"
    }
  ]
}
