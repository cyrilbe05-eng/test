{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/cron/(.*)", "destination": "/api/cron/$1" },
    { "source": "/api/(.*)", "destination": "/api/[...slug]" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/version.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/[...slug].ts": {
      "maxDuration": 60,
      "includeFiles": "api/_helpers/pingu-excited.png"
    },
    "api/cron/budget-nudge.ts": {
      "maxDuration": 60,
      "includeFiles": "api/_helpers/pingu-excited.png"
    }
  },
  "crons": [
    {
      "path": "/api/cron/budget-nudge",
      "schedule": "0 9 * * 1"
    }
  ]
}
